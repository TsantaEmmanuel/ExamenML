
import itertools
import pandas as pd
from functools import lru_cache

# -------------------------
# CHECK WINNER
# -------------------------
def check_winner(board):
    wins = [
        (0,1,2), (3,4,5), (6,7,8),
        (0,3,6), (1,4,7), (2,5,8),
        (0,4,8), (2,4,6)
    ]git 
    for i, j, k in wins:
        if board[i] == board[j] == board[k] != 0:
            return board[i]
    return 0


# FULL BOARD

def is_full(board):
    return all(cell != 0 for cell in board)


# MINIMAX + CACHE

@lru_cache(maxsize=None)
def minimax_cached(board_tuple, player):
    board = list(board_tuple)
    
    winner = check_winner(board)
    
    if winner == 1:
        return 1
    elif winner == -1:
        return -1
    elif is_full(board):
        return 0
    
    if player == 1:
        best = -float('inf')
        for i in range(9):
            if board[i] == 0:
                board[i] = 1
                val = minimax_cached(tuple(board), -1)
                board[i] = 0
                best = max(best, val)
        return best
    else:
        best = float('inf')
        for i in range(9):
            if board[i] == 0:
                board[i] = -1
                val = minimax_cached(tuple(board), 1)
                board[i] = 0
                best = min(best, val)
        return best

# -------------------------
# VALID STATE (tour de X)
# -------------------------
def is_valid(board):
    return board.count(1) == board.count(-1)

# -------------------------
# ENCODING
# -------------------------
def encode_board(board):
    features = []
    for cell in board:
        features.append(1 if cell == 1 else 0)
        features.append(1 if cell == -1 else 0)
    return features

# -------------------------
# GENERATE STATES
# -------------------------
def generate_all_states():
    for board in itertools.product([0, 1, -1], repeat=9):
        board = list(board)
        
        if not is_valid(board):
            continue
        
        if check_winner(board) != 0:
            continue
        
        yield board

# -------------------------
# GENERATE DATASET
# -------------------------
def generate_dataset():
    data = []
    
    for idx, board in enumerate(generate_all_states()):
        
        if idx % 500 == 0:
            print(f"Progression: {idx}")
        
        result = minimax_cached(tuple(board), 1)
        
        x_wins = 1 if result == 1 else 0
        is_draw = 1 if result == 0 else 0
        
        row = encode_board(board) + [x_wins, is_draw]
        data.append(row)
    
    columns = []
    for i in range(9):
        columns.append(f'c{i}_x')
        columns.append(f'c{i}_o')
    columns += ['x_wins', 'is_draw']
    
    df = pd.DataFrame(data, columns=columns)
    
    # Sauvegarde dans Colab
    df.to_csv("dataset.csv", index=False)
    
    print("\n✅ Dataset généré !")
    print("Shape :", df.shape)
    
    return df

# RUN
df = generate_dataset()

